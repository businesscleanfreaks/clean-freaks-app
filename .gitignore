# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/prisma/dev.db-journal

# backups (full app copies — 326 MB, no need in git)
/backups/

# data exports (contains sensitive business data)
/data-exports/*.json
!data-exports/.gitkeep

# config
.config/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Supabase connection strings (contains passwords)
SUPABASE_CONNECTION_STRING.txt

# Session secrets (contains sensitive keys)
SESSION_SECRET.txt

# Backup directories (keep locally, don't push)
Emergency-Backup*/
Emergency-Backups/
pre-restructure-backup*/
.local-db/
# Claude Code (ignore local state, share commands and settings)
.claude/*
!.claude/commands/
!.claude/settings.json
.DS_Store

# Serwist (generated service worker)
public/sw*
public/swe-worker*

# Sentry Config File
.env.sentry-build-plugin
playwright-report/
.codex-next-dev.err.log
.codex-next-dev.log
