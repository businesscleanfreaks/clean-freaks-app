// Production Schema for PostgreSQL (Supabase)
// This is a copy of the main schema with PostgreSQL provider
// Use this when deploying to production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

